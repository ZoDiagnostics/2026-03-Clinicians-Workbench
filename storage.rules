rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ============================================================================
    // HELPER FUNCTIONS
    // ============================================================================

    /**
     * Check if the current request has valid authentication.
     */
    function isAuthenticated() {
      return request.auth != null;
    }

    /**
     * Check if the authenticated user has a specific role.
     */
    function hasRole(role) {
      return isAuthenticated() && request.auth.token.role == role;
    }

    /**
     * Check if the authenticated user's role is one of the provided roles.
     */
    function hasAnyRole(roles) {
      return isAuthenticated() && request.auth.token.role in roles;
    }

    /**
     * Check if the authenticated user belongs to a specific practice.
     */
    function inPractice(practiceId) {
      return isAuthenticated() && request.auth.token.practiceId == practiceId;
    }

    /**
     * Check if the authenticated user is a clinician (any clinician role).
     */
    function isClinician() {
      return hasAnyRole(['clinician_auth', 'clinician_noauth', 'clinician_admin']);
    }

    /**
     * Check if the authenticated user has clinical_staff role.
     */
    function isClinicalStaff() {
      return hasRole('clinical_staff');
    }

    /**
     * Check if the authenticated user has admin or clinician_admin role.
     */
    function isAdminOrClinicianAdmin() {
      return hasAnyRole(['admin', 'clinician_admin']);
    }

    // ============================================================================
    // CAPSULE STUDIES DIRECTORY
    // ============================================================================

    /**
     * Capsule Study Videos: capsule-studies/{practiceId}/{procedureId}/{filename}
     *
     * - Clinical staff and clinician roles in the same practice can upload
     * - Maximum file size: 50GB
     * - Allowed content types: video/* and application/octet-stream (for raw capsule data)
     * - Clinical roles in practice can read for review
     */
    match /capsule-studies/{practiceId}/{procedureId}/{filename} {
      // Upload: Clinical staff and clinicians in practice
      allow write: if inPractice(practiceId) &&
                     (isClinicalStaff() || isClinician()) &&
                     request.resource.size <= 50 * 1024 * 1024 * 1024 && // 50GB max
                     (request.resource.contentType.matches('video/.*') ||
                      request.resource.contentType == 'application/octet-stream');

      // Read: Clinical roles in practice
      allow read: if inPractice(practiceId) && (isClinicalStaff() || isClinician());

      // Delete: Clinical staff and clinicians can delete own uploads
      allow delete: if inPractice(practiceId) && (isClinicalStaff() || isClinician());
    }

    // ============================================================================
    // REPORT PDF DIRECTORY
    // ============================================================================

    /**
     * Report PDFs: report-pdfs/{practiceId}/{reportId}/{filename}
     *
     * - Cloud Functions can write (via admin SDK)
     * - Clinical roles in the same practice can read
     */
    match /report-pdfs/{practiceId}/{reportId}/{filename} {
      // Cloud Functions writes via admin SDK; Firebase rules cannot block admin SDK
      // This rule allows clinical roles to read
      allow read: if inPractice(practiceId) && (isClinicalStaff() || isClinician());

      // Deny direct user writes
      allow write: if false;
    }

    // ============================================================================
    // PATIENT REPORT PDF DIRECTORY
    // ============================================================================

    /**
     * Patient-facing Report PDFs: patient-report-pdfs/{practiceId}/{reportId}/{filename}
     *
     * - Cloud Functions can write (translated/de-identified versions)
     * - Clinical roles in practice can read
     */
    match /patient-report-pdfs/{practiceId}/{reportId}/{filename} {
      allow read: if inPractice(practiceId) && (isClinicalStaff() || isClinician());
      allow write: if false;
    }

    // ============================================================================
    // EDUCATION MATERIALS DIRECTORY
    // ============================================================================

    /**
     * Education Materials: education-materials/{practiceId}/{filename}
     *
     * - Admin and clinician_admin can upload
     * - All authenticated users in practice can read
     */
    match /education-materials/{practiceId}/{filename} {
      // Upload: Admin and clinician_admin only
      allow write: if inPractice(practiceId) && isAdminOrClinicianAdmin();

      // Read: All authenticated users in practice
      allow read: if inPractice(practiceId) && isAuthenticated();

      // Delete: Admin and clinician_admin only
      allow delete: if inPractice(practiceId) && isAdminOrClinicianAdmin();
    }

    // ============================================================================
    // TEMPORARY UPLOADS DIRECTORY
    // ============================================================================

    /**
     * Temporary files for in-progress uploads: temp/{userId}/{filename}
     *
     * - Authenticated users can upload to their own temp directory
     * - Expires after 7 days (client-side cleanup recommended)
     */
    match /temp/{userId}/{filename} {
      allow write: if request.auth.uid == userId &&
                     request.resource.size <= 10 * 1024 * 1024 * 1024; // 10GB max for temp
      allow read: if request.auth.uid == userId;
      allow delete: if request.auth.uid == userId;
    }

    // ============================================================================
    // DEFAULT DENY
    // ============================================================================

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
