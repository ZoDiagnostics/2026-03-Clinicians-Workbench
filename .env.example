# ═══════════════════════════════════════════════════════════════════
# ZoCW Firebase Configuration
# ═══════════════════════════════════════════════════════════════════
# INSTRUCTIONS:
# 1. Copy this file to .env in the project root
# 2. Go to Firebase Console → console.firebase.google.com
# 3. Select your project (clinicians-workbench)
# 4. Click the gear icon → Project Settings → General tab
# 5. Scroll to "Your apps" section → select your Web app
# 6. Copy each value from the SDK config snippet below
#
# WARNING: Do NOT use placeholder values. Every value below must
# come from your actual Firebase Console. Fake keys like
# "AIzaSyA-Studio-Manual-Fix-123" will NEVER work.
# ═══════════════════════════════════════════════════════════════════

# From Firebase Console → Project Settings → General → Your apps → SDK config
VITE_FIREBASE_API_KEY=paste_your_real_apiKey_here
VITE_FIREBASE_AUTH_DOMAIN=paste_your_real_authDomain_here
VITE_FIREBASE_PROJECT_ID=paste_your_real_projectId_here
VITE_FIREBASE_STORAGE_BUCKET=paste_your_real_storageBucket_here
VITE_FIREBASE_MESSAGING_SENDER_ID=paste_your_real_messagingSenderId_here
VITE_FIREBASE_APP_ID=paste_your_real_appId_here

# ═══════════════════════════════════════════════════════════════════
# Environment Configuration (these can stay as-is for development)
# ═══════════════════════════════════════════════════════════════════
VITE_ENVIRONMENT=development
VITE_LOG_LEVEL=debug
VITE_ENABLE_DEMO_MODE=false
VITE_ENABLE_ANALYTICS=true
VITE_APP_NAME=Zo Clinicians Workbench
VITE_APP_VERSION=3.1.0
